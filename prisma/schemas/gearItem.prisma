model GearItem {
  id String @id @default(uuid())

  providerId String
  provider   User   @relation(fields: [providerId], references: [id])

  categoryName String
  category   Category @relation(fields: [categoryName], references: [name], onUpdate: Cascade)

  name              String
  brand             String?
  description       String
  rentalPricePerDay Float
  depositAmount     Float?

  stock          Int
  availableStock Int

  condition GearCondition
  status    GearStatus    @default(AVAILABLE)

  image String?

  rentalItems RentalOrderItem[]
  reviews     Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([categoryName])
  @@index([status])
  @@index([condition])
  @@map("Gears")
}
