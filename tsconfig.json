{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "lib": ["ESNext"],

    "outDir": "./dist",
    // "rootDir": "./src",

    "types": ["node", "express"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true,
    "declaration": true,

    "noUncheckedIndexedAccess": true,
    "isolatedModules": true,

    "moduleDetection": "force"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
